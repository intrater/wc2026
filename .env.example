# ---- Supabase ----
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. NEVER expose to the client. Used by the cron/ingest route to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- API-Football (api-sports.io, direct) ----
# Pro tier (~$19/mo). Do NOT use the free tier in production (100 req/day).
API_FOOTBALL_KEY=your-api-football-key
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# ---- Cron auth ----
# Vercel sends this as `Authorization: Bearer <CRON_SECRET>` to /api/poll.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-long-random-secret

# ---- App config ----
# The single admin's email (matched on sign-in to grant admin rights).
ADMIN_EMAIL=john.intrater@gmail.com
# Public base URL used for magic-link redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Morning digest email ----
# Signs unsubscribe links in digest emails. Independent of CRON_SECRET so the two
# can rotate separately (rotating this invalidates unsubscribe links in sent email).
# Generate with: openssl rand -hex 32
DIGEST_LINK_SECRET=your-long-random-secret

# ---- Email (Resend SMTP) ----
# Used for pick receipts and the morning digest. Unset locally → emails log to console.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
EMAIL_FROM=pool@wc2026.johnintrater.com

# ---- Anthropic (daily recap narrative) ----
# Server-only. NEVER expose to the client. Do NOT prefix with NEXT_PUBLIC_.
# Without it, recaps still publish with the deterministic stats digest.
ANTHROPIC_API_KEY=your-anthropic-api-key
